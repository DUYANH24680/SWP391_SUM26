<?xml version="1.0" encoding="UTF-8"?>
<!--
    context.xml - Tomcat 10 / JDK 17 / NetBeans 17
    DBCP2 Connection Pool (built-in with Tomcat 10, no extra jar needed)
-->
<Context path="/WebProject">

    <Resource
        name="jdbc/SENAFRUIT"
        auth="Container"
        type="javax.sql.DataSource"
        factory="org.apache.tomcat.dbcp.dbcp2.BasicDataSourceFactory"
        driverClassName="com.microsoft.sqlserver.jdbc.SQLServerDriver"
        url="jdbc:sqlserver://localhost:1433;databaseName=SENAFRUIT;encrypt=false;trustServerCertificate=true;loginTimeout=30"
        username="sa"
        password="123"

        initialSize="3"
        maxTotal="20"
        maxIdle="10"
        minIdle="3"
        maxWaitMillis="5000"

        validationQuery="SELECT 1"
        testOnBorrow="true"
        testWhileIdle="true"
        timeBetweenEvictionRunsMillis="30000"
        minEvictableIdleTimeMillis="60000"

        removeAbandonedOnBorrow="true"
        removeAbandonedOnMaintenance="true"
        removeAbandonedTimeout="60"
        logAbandoned="true"
    />

</Context>
